
// Import the audio asset so Astro/Vite bundles it correctly during build
import bgmUrl from './exhibit_background_music.mp3';

class ExhibitAudio {
  constructor() {
    this.audio = null;
    this.isInitialized = false;
    this.isMuted = false;
    this.buttonEl = null;
  }

  // Initialize the audio instance
  init(volume = 0.5) {
    if (typeof window === 'undefined' || this.isInitialized) return;

    this.audio = new Audio(bgmUrl);
    this.audio.loop = true;
    this.audio.volume = Math.max(0, Math.min(1, volume));
    this.isInitialized = true;
  }

  // Play background music (Handles browser autoplay restrictions)
  async play() {
    if (!this.audio) this.init();
    
    try {
      await this.audio.play();
    } catch (err) {
      console.warn('Autoplay blocked by browser. User interaction required.', err);
    }
  }

  // Toggle mute / unmute state
  toggleMute() {
    if (!this.audio) this.init();

    this.isMuted = !this.isMuted;
    this.audio.muted = this.isMuted;
    this.updateButtonUI();

    // If audio was paused when unmuting, start playing
    if (!this.isMuted && this.audio.paused) {
      this.play();
    }

    return this.isMuted;
  }

  // Inject a small, fixed mute button onto the screen
  createMuteButton() {
    if (typeof window === 'undefined' || this.buttonEl) return;

    // Create the button element
    const btn = document.createElement('button');
    btn.id = 'audio-mute-btn';
    btn.setAttribute('aria-label', 'Toggle Audio Mute');
    
    // Apply styling directly for a small, subtle floating button
    Object.assign(btn.style, {
      position: 'fixed',
      bottom: '1rem',
      right: '1rem',
      zIndex: '9999',
      width: '36px',
      height: '36px',
      borderRadius: '50%',
      border: '1px solid rgba(255, 255, 255, 0.2)',
      backgroundColor: 'rgba(0, 0, 0, 0.6)',
      color: '#ffffff',
      fontSize: '14px',
      cursor: 'pointer',
      display: 'flex',
      alignItems: 'center',
      justifyContent: 'center',
      backdropFilter: 'blur(4px)',
      transition: 'transform 0.2s ease, background-color 0.2s ease',
      boxShadow: '0 2px 8px rgba(0,0,0,0.2)'
    });

    // Hover effect
    btn.onmouseenter = () => (btn.style.transform = 'scale(1.1)');
    btn.onmouseleave = () => (btn.style.transform = 'scale(1)');

    // Click handler
    btn.onclick = () => this.toggleMute();

    document.body.appendChild(btn);
    this.buttonEl = btn;
    this.updateButtonUI();
  }

  // Update button icon based on state
  updateButtonUI() {
    if (!this.buttonEl) return;
    this.buttonEl.innerHTML = this.isMuted ? '🔇' : '🔊';
    this.buttonEl.title = this.isMuted ? 'Unmute Audio' : 'Mute Audio';
  }

  // Start music on first click anywhere & display the mute button
  enableAutoplayOnInteraction() {
    if (typeof window === 'undefined') return;

    // Create the button right away
    this.createMuteButton();

    const startOnInteraction = () => {
      if (!this.isMuted) {
        this.play();
      }
      window.removeEventListener('click', startOnInteraction);
      window.removeEventListener('keydown', startOnInteraction);
    };

    window.addEventListener('click', startOnInteraction, { once: true });
    window.addEventListener('keydown', startOnInteraction, { once: true });
  }
}

// Export a single instance to use across your site
export const exhibitAudio = new ExhibitAudio();
